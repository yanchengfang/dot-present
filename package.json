{
  "name": "dot-present",
  "version": "1.0.0",
  "description": "vue3 + Ts UI components library",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "dev": "pnpm -C examples dev",
    "start": "pnpm -C examples-cra start",
    "build": "rollup -c && node scripts/generate-types.cjs",
    "test": "pnpm -C packages/components test",
    "prepublish": "echo Depchecking subpackages... && node scripts/add-subpackages-deps.mjs",
    "publish": "npx lerna publish",
    "postpublish": "echo Publish completed!"
  },
  "files": [
    "/dist",
    "LICENSE"
  ],
  "keywords": [
    "UI",
    "vue3",
    "Ts",
    "Vite"
  ],
  "author": "Summery",
  "license": "ISC",
  "packageManager": "pnpm@10.26.2",
  "dependencies": {
    "@dot-present/components": "workspace:*",
    "@dot-present/theme-chalk": "workspace:*",
    "@dot-present/utils": "workspace:*",
    "@dot-present/virtual-list": "workspace:*",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "vue": "^3.5.29",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@rollup/plugin-terser": "^1.0.0",
    "@tsconfig/node18": "^18.2.6",
    "@tsconfig/node24": "^24.0.4",
    "@vitejs/plugin-vue": "^6.0.5",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "jsdom": "^28.1.0",
    "lerna": "^9.0.7",
    "rollup": "^4.59.0",
    "rollup-plugin-copy": "^3.5.0",
    "rollup-plugin-delete": "^3.0.2",
    "rollup-plugin-postcss": "^4.0.2",
    "rollup-plugin-typescript2": "^0.36.0",
    "rollup-plugin-vue": "^6.0.0",
    "sass": "^1.98.0",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.6",
    "vitest": "^4.1.0"
  }
}
