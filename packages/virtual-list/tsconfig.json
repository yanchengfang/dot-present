{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.react-library.json",
  "include": ["src/**/*.ts", "src/**/*.tsx"],
  "exclude": ["src/**/*.test.ts", "node_modules"],
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "noEmit": true,
    "tsBuildInfoFile": "../../node_modules/.tmp/tsconfig.virtual-list.tsbuildinfo"
  }
}
