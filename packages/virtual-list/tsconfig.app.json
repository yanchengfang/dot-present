{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM"],
    "jsx": "react-jsx",
    "jsxImportSource": "react",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "skipLibCheck": false,
    "composite": true,
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.app.tsbuildinfo",
    "noEmit": false,
    "declaration": true,
    "declarationDir": "./temp-types",
    "emitDeclarationOnly": true,
    "outDir": "./dist",
    "rootDir": "./src"
  },
  "include": ["src/**/*.tsx", "src/**/*.ts"],
  "exclude": [
    "src/**/*.test.ts",
    "node_modules",
    "**/*.vue",
    "../vue-shim.d.ts",
    "../../vue-shim.d.ts",
    "../../node_modules/@vue",
    "../../node_modules/vue"
  ]
}
